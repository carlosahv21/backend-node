# ── Servidor ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (PostgreSQL) ────────────────────────────────────────
DB_CLIENT=pg
DB_HOST=localhost
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=tu_basedatos
DB_PORT=5432

# ── Autenticación (JWT) ───────────────────────────────────────────────
# Obligatorio en producción. Genera uno con: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=1d

# ── CORS ──────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma. Obligatorio en producción.
# Ej: https://app.midominio.com,https://admin.midominio.com
CORS_ORIGIN=

# ── Frontend ──────────────────────────────────────────────────────────
# Usado para construir el link de recuperación de contraseña.
FRONTEND_URL=http://localhost:5173

# ── Debug ─────────────────────────────────────────────────────────────
# Si está definido (cualquier valor truthy), escribe el historial de
# consultas SQL en ./logs. Dejar vacío para desactivar.
DEBUG_SQL_QUERY=
