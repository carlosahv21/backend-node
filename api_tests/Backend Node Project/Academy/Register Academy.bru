meta {
  name: Register Academy
  type: http
  seq: 1
}

post {
  url: {{base_url}}/academies/register
  body: json
  auth: inherit
}

body:json {
  {
    "academy": {
      "name": "Nombre de tu Academia",
      "address": "Dirección física (opcional)",
