    },
    "user": {
      "first_name": "Nombre del Admin",
      "last_name": "Apellido del Admin",
      "email": "admin@academia.com",
      "password": "password_de_al_menos_8_caracteres"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
